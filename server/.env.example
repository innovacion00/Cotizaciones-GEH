PORT=3000
MONGODB_URI=mongodb://localhost:27017/cotizador
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
CLIENT_URL=http://localhost:4321
NODE_ENV=development

# Si se define, todo usuario que se auto-registre se une automáticamente a este
# workspace con rol "sales" (un admin lo promueve manualmente si corresponde).
# Si se deja vacío, cada registro crea su propio workspace nuevo (modelo multi-tenant).
DEFAULT_WORKSPACE_ID=

# Gmail API (Google Workspace OAuth2)
# 1. Google Cloud Console → APIs → activar Gmail API
# 2. OAuth consent screen → Interno → scope gmail.send
# 3. Credenciales → Crear OAuth Client ID:
#    - Recomendado: tipo "Aplicación de escritorio"
#    - Alternativa: tipo "Web" + URI http://127.0.0.1:3333/oauth2callback
# 4. npm run gmail:auth -w server → copiar refresh token aquí
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=cotizaciones@tu-empresa.com

# Legacy SMTP (no usado si Gmail API está configurado)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password

AUTOCORE_API_URL=https://api.autocore.example.com
AUTOCORE_API_KEY=your_autocore_api_key
