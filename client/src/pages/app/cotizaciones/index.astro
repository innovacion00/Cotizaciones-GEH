---
import AppLayout from '../../../layouts/AppLayout.astro';
---
<AppLayout title="Cotizaciones">
  <div class="cotizaciones">
    <div class="cotizaciones__toolbar">
      <button id="new-quote-btn" class="btn btn--primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nueva cotización
      </button>
      <div class="cotizaciones__filters">
        <select id="status-filter" class="form-input">
          <option value="">Todos los estados</option>
          <option value="draft">Borrador</option>
          <option value="sent">Enviada</option>
          <option value="viewed">Vista</option>
          <option value="accepted">Aceptada</option>
          <option value="rejected">Rechazada</option>
          <option value="expired">Expirada</option>
        </select>
      </div>
    </div>

    <div id="quotes-list" class="cotizaciones__list">
      <p class="cotizaciones__loading">Cargando cotizaciones...</p>
    </div>
  </div>

  <!-- Modal paso 1: Datos del cliente -->
  <div id="client-modal" class="modal" style="display:none;">
    <div class="modal__backdrop"></div>
    <div class="modal__content card">
      <h2 class="modal__title">Nueva cotización</h2>
      <form id="client-form" class="modal__form">
        <div class="form-group">
          <label class="form-label">Nombre del cliente *</label>
          <input class="form-input" name="clientName" required />
        </div>
        <div class="form-group">
          <label class="form-label">Empresa</label>
          <input class="form-input" name="clientCompany" />
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input class="form-input" type="email" name="clientEmail" />
        </div>
        <div class="form-group">
          <label class="form-label">Teléfono</label>
          <input class="form-input" name="clientPhone" />
        </div>
        <div class="modal__actions">
          <button type="button" id="cancel-client-modal" class="btn btn--secondary">Cancelar</button>
          <button type="submit" class="btn btn--primary">Siguiente →</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Contenedor del wizard React -->
  <div id="hotel-wizard-root"></div>
</AppLayout>

<script>
  import api from '../../../lib/api.js';
  import { getWorkspaceId } from '../../../lib/auth.js';
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import HotelBookingWizard from '../../../components/react/HotelBookingWizard.jsx';

  const wsId = getWorkspaceId();
  const listEl = document.getElementById('quotes-list') as HTMLElement;
  const clientModal = document.getElementById('client-modal') as HTMLElement;
  const wizardRoot = document.getElementById('hotel-wizard-root') as HTMLElement;
  let reactRoot: import('react-dom/client').Root | null = null;
  let pendingClient: Record<string, string | undefined> | null = null;

  // ── Listado ──────────────────────────────────────────────────────────────
  async function loadQuotes(status = '') {
    listEl.innerHTML = '<p class="cotizaciones__loading">Cargando...</p>';
    try {
      const params = new URLSearchParams({ workspaceId: wsId ?? '', limit: '50' });
      if (status) params.set('status', status);
      const data = await api.get(`/api/v1/quotes?${params}`);
      renderQuotes(data.quotes || []);
    } catch (err) {
      listEl.innerHTML = `<p class="cotizaciones__error">Error: ${(err as Error).message}</p>`;
    }
  }

  function renderQuotes(quotes: any[]) {
    if (!quotes.length) {
      listEl.innerHTML = '<p class="cotizaciones__empty">No hay cotizaciones. ¡Crea la primera!</p>';
      return;
    }
    listEl.innerHTML = `
      <div class="cotizaciones__header-row">
        <span>Cliente</span><span>Empresa</span><span>Estado</span><span>Total</span><span>Fecha</span><span></span>
      </div>
      ${quotes.map((q: any) => `
        <div class="cotizaciones__row">
          <div class="cotizaciones__cell cotizaciones__cell--client">${q.client.name}</div>
          <div class="cotizaciones__cell">${q.client.company || '—'}</div>
          <div class="cotizaciones__cell"><span class="badge badge--${q.status}">${q.status}</span></div>
          <div class="cotizaciones__cell cotizaciones__cell--total">$${(q.totals?.total || 0).toLocaleString('es-CO', {minimumFractionDigits: 0})}</div>
          <div class="cotizaciones__cell cotizaciones__cell--date">${new Date(q.updatedAt).toLocaleDateString('es-CO')}</div>
          <div class="cotizaciones__cell">
            <a href="/app/cotizaciones/${q._id}" class="btn btn--secondary btn--sm">Editar</a>
          </div>
        </div>
      `).join('')}
    `;
  }

  // ── Paso 1: modal cliente ─────────────────────────────────────────────────
  function openClientModal() { clientModal.style.display = 'flex'; }

  function closeClientModal() {
    clientModal.style.display = 'none';
    (document.getElementById('client-form') as HTMLFormElement).reset();
    pendingClient = null;
  }

  // ── Paso 2: wizard React ──────────────────────────────────────────────────
  function mountWizard(client: Record<string, string | undefined>) {
    pendingClient = client;
    clientModal.style.display = 'none';
    if (reactRoot) { reactRoot.unmount(); reactRoot = null; }

    reactRoot = createRoot(wizardRoot);
    reactRoot.render(createElement(HotelBookingWizard, {
      onConfirm: async (item: any) => {
        try {
          const quote = await api.post(`/api/v1/quotes?workspaceId=${wsId}`, {
            client: pendingClient,
            items: [item],
            taxRate: 0.19,
          });
          window.location.href = `/app/cotizaciones/${quote.quote._id}`;
        } catch (err) {
          alert(`Error al crear cotización: ${(err as Error).message}`);
        }
      },
      onCancel: () => {
        reactRoot!.unmount();
        reactRoot = null;
        openClientModal();
      },
    }));
  }

  // ── Eventos ───────────────────────────────────────────────────────────────
  document.getElementById('status-filter')!.addEventListener('change', (e) => loadQuotes((e.target as HTMLSelectElement).value));
  document.getElementById('new-quote-btn')!.addEventListener('click', openClientModal);
  document.getElementById('cancel-client-modal')!.addEventListener('click', closeClientModal);
  document.querySelector('#client-modal .modal__backdrop')!.addEventListener('click', closeClientModal);

  document.getElementById('client-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(e.currentTarget as HTMLFormElement);
    mountWizard({
      name: data.get('clientName') as string,
      company: (data.get('clientCompany') as string) || undefined,
      email: (data.get('clientEmail') as string) || undefined,
      phone: (data.get('clientPhone') as string) || undefined,
    });
  });

  loadQuotes();
</script>

<style>
  .cotizaciones { display: flex; flex-direction: column; gap: var(--space-6); }
  .cotizaciones__toolbar { display: flex; justify-content: space-between; align-items: center; }
  .cotizaciones__filters select { width: 200px; }

  .modal { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 50; }
  .modal__backdrop { position: absolute; inset: 0; background: rgba(0,0,0,.4); }
  .modal__content { position: relative; width: 100%; max-width: 480px; z-index: 1; }
  .modal__title { font-size: var(--text-xl); font-weight: var(--font-semibold); margin-bottom: var(--space-6); }
  .modal__form { display: flex; flex-direction: column; gap: var(--space-4); }
  .modal__actions { display: flex; justify-content: flex-end; gap: var(--space-3); margin-top: var(--space-2); }
</style>
