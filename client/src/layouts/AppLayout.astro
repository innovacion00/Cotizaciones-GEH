---
import BaseLayout from './BaseLayout.astro';
const { title = 'App' } = Astro.props;
---
<BaseLayout title={title}>
  <div class="app-layout">
    <aside class="app-layout__sidebar">
      <div class="app-layout__logo">
        <span class="app-layout__logo-text">Cotizador</span>
      </div>
      <nav class="app-layout__nav">
        <a href="/app" class="app-layout__nav-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/app/cotizaciones" class="app-layout__nav-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          Cotizaciones
        </a>
        <a href="/app/catalogo" class="app-layout__nav-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          Catálogo
        </a>
      </nav>
      <div class="app-layout__sidebar-footer">
        <button id="logout-btn" class="app-layout__logout">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Cerrar sesión
        </button>
      </div>
    </aside>

    <div class="app-layout__main">
      <header class="app-layout__topbar">
        <h1 class="app-layout__page-title">{title}</h1>
        <div id="user-info" class="app-layout__user"></div>
      </header>
      <main class="app-layout__content">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  import { logout, getCurrentUser } from '../lib/auth.js';
  import { isAuthenticated } from '../lib/auth.js';

  if (!isAuthenticated()) window.location.href = '/';

  const user = getCurrentUser();
  const el = document.getElementById('user-info');
  if (el && user) el.textContent = user.name;

  document.getElementById('logout-btn')?.addEventListener('click', logout);
</script>

<style>
  .app-layout { display: flex; min-height: 100vh; }

  .app-layout__sidebar {
    width: 240px; background: var(--color-sidebar-bg); color: var(--color-sidebar-text);
    display: flex; flex-direction: column; flex-shrink: 0;
  }
  .app-layout__logo {
    padding: var(--space-6); border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .app-layout__logo-text { font-size: var(--text-xl); font-weight: var(--font-bold); color: #fff; }

  .app-layout__nav { flex: 1; padding: var(--space-4) 0; }
  .app-layout__nav-item {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-6); font-size: var(--text-sm);
    color: var(--color-sidebar-text); transition: background var(--transition), color var(--transition);
    border-left: 3px solid transparent;
  }
  .app-layout__nav-item:hover,
  .app-layout__nav-item.active {
    background: rgba(255,255,255,.06); color: #fff;
    border-left-color: var(--color-sidebar-active);
  }

  .app-layout__sidebar-footer { padding: var(--space-4) var(--space-6); border-top: 1px solid rgba(255,255,255,.08); }
  .app-layout__logout {
    display: flex; align-items: center; gap: var(--space-2); background: none; border: none;
    color: var(--color-sidebar-text); font-size: var(--text-sm); cursor: pointer;
    padding: var(--space-2) 0;
  }
  .app-layout__logout:hover { color: var(--color-danger); }

  .app-layout__main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
  .app-layout__topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--space-4) var(--space-8); background: var(--color-surface);
    border-bottom: 1px solid var(--color-border); box-shadow: var(--shadow-sm);
  }
  .app-layout__page-title { font-size: var(--text-xl); font-weight: var(--font-semibold); }
  .app-layout__user { font-size: var(--text-sm); color: var(--color-text-muted); }
  .app-layout__content { flex: 1; overflow-y: auto; padding: var(--space-8); }
</style>
