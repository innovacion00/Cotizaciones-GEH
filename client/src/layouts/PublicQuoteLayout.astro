---
import BaseLayout from './BaseLayout.astro';
const { title = 'Cotización', branding } = Astro.props;
---
<BaseLayout title={title}>
  <div class="public-layout">
    <header class="public-layout__header" style={branding?.primaryColor ? `border-top: 4px solid ${branding.primaryColor}` : ''}>
      <div class="public-layout__header-inner">
        <span class="public-layout__company">{branding?.companyName || 'Empresa'}</span>
        <span class="public-layout__powered">Cotización digital</span>
      </div>
    </header>
    <main class="public-layout__main">
      <slot />
    </main>
    <footer class="public-layout__footer">
      <p>Este documento es confidencial y ha sido preparado exclusivamente para el destinatario indicado.</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .public-layout { min-height: 100vh; display: flex; flex-direction: column; background: var(--color-bg); }
  .public-layout__header { background: var(--color-surface); border-bottom: 1px solid var(--color-border); border-top: 4px solid var(--color-primary); }
  .public-layout__header-inner { max-width: 800px; margin: auto; padding: var(--space-5) var(--space-6); display: flex; justify-content: space-between; align-items: center; }
  .public-layout__company { font-size: var(--text-xl); font-weight: var(--font-bold); }
  .public-layout__powered { font-size: var(--text-xs); color: var(--color-text-muted); }
  .public-layout__main { flex: 1; max-width: 800px; margin: var(--space-8) auto; padding: 0 var(--space-6); width: 100%; }
  .public-layout__footer { text-align: center; padding: var(--space-8) var(--space-6); font-size: var(--text-xs); color: var(--color-text-muted); border-top: 1px solid var(--color-border); }
</style>
